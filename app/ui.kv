#:kivy 2.2.1

<Wallpaper@Widget>:
    canvas.before:
        Color:
            rgba: 1, 1, 1, 1
        Rectangle:
            source: app.wallpaper_path if app.wallpaper_path else ""
            pos: self.pos
            size: self.size
        Color:
            rgba: (0.96, 0.96, 0.96, 0.4)
        Rectangle:
            pos: self.pos
            size: self.size

<PCTLabel@Label>:
    color: 0.12, 0.12, 0.12, 1

<HomeButton@ButtonBehavior+BoxLayout>:
    icon_source: ""
    label_text: ""
    bg_color: 0.4, 0.5, 0.9, 1
    orientation: "vertical"
    padding: 8
    spacing: 4
    size_hint: 1, 1
    canvas.before:
        Color:
            rgba: root.bg_color
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [16,]
    canvas.after:
        Color:
            rgba: 1, 1, 1, 0.9
        Line:
            width: 1
            rounded_rectangle: (self.x + 1, self.y + 1, self.width - 2, self.height - 2, 16, 16, 16, 16)
    AnchorLayout:
        size_hint: 1, 1
        anchor_x: "center"
        anchor_y: "center"
        Image:
            source: root.icon_source
            size_hint: None, None
            size: "128dp", "128dp"
            allow_stretch: True
            keep_ratio: True
    Label:
        text: root.label_text
        font_size: "16sp"
        color: 1, 1, 1, 1
        size_hint_y: None
        height: "22dp"
        halign: "center"
        valign: "middle"
        text_size: self.size

<SmallIconButton@ButtonBehavior+BoxLayout>:
    icon_source: ""
    bg_color: 0.95, 0.95, 0.95, 1
    size_hint: None, None
    size: "48dp", "48dp"
    canvas.before:
        Color:
            rgba: root.bg_color
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [12,]
    AnchorLayout:
        size_hint: 1, 1
        anchor_x: "center"
        anchor_y: "center"
        Image:
            source: root.icon_source
            size_hint: None, None
            size: "32dp", "32dp"
            allow_stretch: True
            keep_ratio: True

<IconOnlyButton@ButtonBehavior+BoxLayout>:
    icon_source: ""
    bg_color: 0.95, 0.95, 0.95, 1
    size_hint: None, None
    size: "72dp", "72dp"
    canvas.before:
        Color:
            rgba: root.bg_color
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [18,]
    AnchorLayout:
        size_hint: 1, 1
        anchor_x: "center"
        anchor_y: "center"
        Image:
            source: root.icon_source
            size_hint: None, None
            size: "72dp", "72dp"
            allow_stretch: True
            keep_ratio: True

<Pill@Label>:
    canvas.before:
        Color:
            rgba: 1, 0.95, 0.85, 0.9
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [24,]
    color: 0.9, 0.45, 0.0, 1
    padding: 16, 8

<HomeScreen>:
    name: "home"
    FloatLayout:
        Wallpaper:
            size_hint: 1, 1
            pos: 0, 0
        BoxLayout:
            orientation: "vertical"
            padding: 14
            spacing: 8
            size_hint: 1, 1
            BoxLayout:
                orientation: "vertical"
                size_hint_y: None
                height: "96dp"
                padding: 6
                canvas.before:
                    Color:
                        rgba: 1, 1, 1, 0.95
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [16,]
                Label:
                    id: time_label
                    text: "07:35"
                    font_size: "54sp"
                    bold: True
                    color: 0, 0, 0, 1
                    size_hint_y: None
                    height: "58dp"
                    text_size: self.size
                    halign: "center"
                    valign: "middle"
                Label:
                    id: date_label
                    text: "Lun, 10 Mar"
                    font_size: "18sp"
                    color: 0.15, 0.15, 0.15, 1
                    size_hint_y: None
                    height: "22dp"
                    text_size: self.size
                    halign: "center"
                    valign: "middle"
            Pill:
                text: "⏰ Proxima alarma: 06:30"
                size_hint_y: None
                height: "34dp"
                halign: "center"
                valign: "middle"
            AnchorLayout:
                size_hint_y: None
                height: "144dp"
                anchor_x: "center"
                anchor_y: "center"
                GridLayout:
                    cols: 2
                    spacing: 12
                    padding: 12, 0
                    size_hint: None, None
                    width: "320dp"
                    height: "144dp"
                    row_default_height: "144dp"
                    row_force_default: True
                    col_default_width: "154dp"
                    col_force_default: True
                    HomeButton:
                        bg_color: 0.31, 0.72, 0.47, 1
                        icon_source: app.story_icon_path
                        label_text: "Cuentos"
                        on_release: root.manager.current = "story_list"
                    HomeButton:
                        bg_color: 0.29, 0.45, 0.89, 1
                        icon_source: app.alarm_icon_path
                        label_text: "Alarmas"
                        on_release: root.manager.current = "alarm_list"

<StoryCard>:
    orientation: "vertical"
    padding: 8
    spacing: 6
    canvas.before:
        Color:
            rgba: 1, 1, 1, 0.9
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [14,]
    on_release: app.open_story(self.story)
    AsyncImage:
        source: root.story.get("icon_path", "")
    Label:
        text: root.story.get("title", "")
        font_size: "14sp"
        color: 0.1, 0.1, 0.1, 1

<StoryImage@AsyncImage>:


<SoundImage@AsyncImage>:


<SoundCard>:
    orientation: "vertical"
    padding: 6
    spacing: 4
    canvas.before:
        Color:
            rgba: 1, 1, 1, 0.9
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [12,]
    on_release: app.choose_alarm_sound(self.sound)
    SoundImage:
        source: root.sound.get("image_path", "")
    Label:
        text: root.sound.get("label", "")
        font_size: "12sp"
        color: 0.1, 0.1, 0.1, 1

<AlarmCard>:
    orientation: "horizontal"
    padding: 12
    spacing: 10
    size_hint_y: None
    height: "52dp"
    canvas.before:
        Color:
            rgba: 1, 1, 1, 0.9
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [12,]
    on_release: app.root.current = "alarm_time"
    BoxLayout:
        orientation: "vertical"
        Label:
            text: root.alarm.get("time", "")
            font_size: "20sp"
            color: 0.1, 0.1, 0.1, 1
        Label:
            text: root.alarm.get("days", "") + "  •  " + root.alarm.get("sound", "")
            font_size: "12sp"
            color: 0.4, 0.4, 0.4, 1

<StoryListScreen>:
    name: "story_list"
    FloatLayout:
        Wallpaper:
            size_hint: 1, 1
            pos: 0, 0
        BoxLayout:
            orientation: "vertical"
            size_hint: 1, 1
            BoxLayout:
                size_hint_y: None
                height: "60dp"
                padding: 12, 10
                spacing: 10
                SmallIconButton:
                    icon_source: app.home_icon_path
                    on_release: root.manager.current = "home"
                Label:
                    text: "CUENTOS"
                    bold: True
                    font_size: "20sp"
                    color: 0.1, 0.1, 0.1, 1
                    text_size: self.size
                    halign: "center"
                    valign: "middle"
            ScrollView:
                GridLayout:
                    id: story_grid
                    cols: 2
                    spacing: 12
                    padding: 12
                    size_hint_y: None
                    height: self.minimum_height
                    row_default_height: "150dp"
                    row_force_default: True

<StoryPlayerScreen>:
    name: "story_player"
    FloatLayout:
        Wallpaper:
            size_hint: 1, 1
            pos: 0, 0
        BoxLayout:
            orientation: "horizontal"
            size_hint: None, None
            height: "48dp"
            width: "110dp"
            spacing: 6
            padding: 8, 8
            pos_hint: {"x": 0.02, "top": 0.98}
            SmallIconButton:
                icon_source: app.back_icon_path
                on_release: root.manager.current = "story_list"
            SmallIconButton:
                icon_source: app.home_icon_path
                on_release: root.manager.current = "home"
        BoxLayout:
            orientation: "vertical"
            padding: 14
            spacing: 8
            size_hint: 1, 1
            Widget:
                size_hint_y: None
                height: "24dp"
            BoxLayout:
                size_hint_y: None
                height: "150dp"
                AnchorLayout:
                    anchor_x: "center"
                    anchor_y: "center"
                    StoryImage:
                        source: root.story_icon
                        size_hint: None, None
                        size: "120dp", "120dp"
            BoxLayout:
                size_hint_y: None
                height: "48dp"
                orientation: "vertical"
                Label:
                    text: root.story_title
                    font_size: "18sp"
                    color: 0.1, 0.1, 0.1, 1
                    text_size: self.size
                    halign: "center"
                    valign: "middle"
                Label:
                    text: "Fábula clásica"
                    font_size: "12sp"
                    color: 0.5, 0.5, 0.5, 1
                    text_size: self.size
                    halign: "center"
                    valign: "middle"
            ProgressBar:
                max: 100
                value: 35
                size_hint_y: None
                height: "14dp"
            AnchorLayout:
                size_hint_y: None
                height: "96dp"
                anchor_x: "center"
                anchor_y: "center"
                GridLayout:
                    cols: 3
                    spacing: 12
                    size_hint: None, None
                    width: "240dp"
                    height: "72dp"
                    col_default_width: "72dp"
                    col_force_default: True
                    row_default_height: "72dp"
                    row_force_default: True
                    IconOnlyButton:
                        icon_source: app.prev_icon_path
                    IconOnlyButton:
                        icon_source: root.play_icon
                        on_release: root.toggle_play()
                    IconOnlyButton:
                        icon_source: app.next_icon_path

<AlarmListScreen>:
    name: "alarm_list"
    FloatLayout:
        Wallpaper:
            size_hint: 1, 1
            pos: 0, 0
        BoxLayout:
            orientation: "vertical"
            size_hint: 1, 1
            BoxLayout:
                size_hint_y: None
                height: "60dp"
                spacing: 10
                Button:
                    background_normal: ""
                    background_down: ""
                    background_color: 0.95, 0.95, 0.95, 1
                    size_hint_x: None
                    width: "60dp"
                    on_release: root.manager.current = "home"
                    Image:
                        source: app.home_icon_path
                        allow_stretch: True
                        keep_ratio: True
                Label:
                    text: "ALARMS"
                    bold: True
                    font_size: "20sp"
                    color: 0.1, 0.1, 0.1, 1
                    text_size: self.size
                    halign: "center"
                    valign: "middle"
                Button:
                    text: "+"
                    size_hint_x: None
                    width: "60dp"
                    on_release: root.manager.current = "alarm_time"
            ScrollView:
                GridLayout:
                    id: alarm_list_box
                    cols: 1
                    spacing: 10
                    padding: 12
                    size_hint_y: None
                    height: self.minimum_height

<AlarmTimeScreen>:
    name: "alarm_time"
    FloatLayout:
        Wallpaper:
            size_hint: 1, 1
            pos: 0, 0
        BoxLayout:
            orientation: "vertical"
            padding: 12
            spacing: 10
            size_hint: 1, 1
            BoxLayout:
                size_hint_y: None
                height: "60dp"
                spacing: 10
                Button:
                    background_normal: ""
                    background_down: ""
                    background_color: 0.95, 0.95, 0.95, 1
                    size_hint_x: None
                    width: "60dp"
                    on_release: root.manager.current = "alarm_list"
                    Image:
                        source: app.back_icon_path
                        allow_stretch: True
                        keep_ratio: True
                Label:
                    text: "Alarm Time"
                    bold: True
                    font_size: "20sp"
                    text_size: self.size
                    halign: "center"
                    valign: "middle"
                Button:
                    text: "Next"
                    size_hint_x: None
                    width: "80dp"
                    on_release: root.manager.current = "alarm_sound"
            Label:
                text: "06:30"
                font_size: "48sp"
            GridLayout:
                cols: 7
                size_hint_y: None
                height: "50dp"
                spacing: 6
                Button:
                    text: "L"
                Button:
                    text: "M"
                Button:
                    text: "X"
                Button:
                    text: "J"
                Button:
                    text: "V"
                Button:
                    text: "S"
                Button:
                    text: "D"
            BoxLayout:
                size_hint_y: None
                height: "50dp"
                spacing: 10
                Label:
                    text: "Sonido"
                Button:
                    text: "🐓 " + root.selected_sound_label
                    on_release: root.manager.current = "alarm_sound"

<AlarmSoundScreen>:
    name: "alarm_sound"
    FloatLayout:
        Wallpaper:
            size_hint: 1, 1
            pos: 0, 0
        BoxLayout:
            orientation: "vertical"
            padding: 12
            spacing: 8
            size_hint: 1, 1
            BoxLayout:
                size_hint_y: None
                height: "60dp"
                spacing: 10
                Button:
                    background_normal: ""
                    background_down: ""
                    background_color: 0.95, 0.95, 0.95, 1
                    size_hint_x: None
                    width: "60dp"
                    on_release: root.manager.current = "alarm_time"
                    Image:
                        source: app.back_icon_path
                        allow_stretch: True
                        keep_ratio: True
                Label:
                    text: "Alarm Sound"
                    bold: True
                    font_size: "20sp"
                    text_size: self.size
                    halign: "center"
                    valign: "middle"
                Button:
                    text: "Save"
                    size_hint_x: None
                    width: "80dp"
                    on_release: root.manager.current = "alarm_list"
            ScrollView:
                GridLayout:
                    id: sound_grid
                    cols: 3
                    spacing: 8
                    padding: 8
                    size_hint_y: None
                    height: self.minimum_height
                    row_default_height: "90dp"
                    row_force_default: True

<AlarmRingingScreen>:
    name: "alarm_ringing"
    FloatLayout:
        Wallpaper:
            size_hint: 1, 1
            pos: 0, 0
        BoxLayout:
            orientation: "vertical"
            padding: 16
            spacing: 12
            size_hint: 1, 1
            Label:
                text: "⏰ ALARMA"
                font_size: "32sp"
                bold: True
                color: 0.1, 0.1, 0.1, 1
            Label:
                text: "07:00"
                font_size: "52sp"
                bold: True
                color: 0.1, 0.1, 0.1, 1
            Widget:
            GridLayout:
                cols: 2
                spacing: 12
                size_hint_y: None
                height: "120dp"
                Button:
                    text: "Snooze"
                    font_size: "20sp"
                Button:
                    text: "Stop"
                    font_size: "20sp"

RootScreenManager:
    HomeScreen:
    StoryListScreen:
    StoryPlayerScreen:
    AlarmListScreen:
    AlarmTimeScreen:
    AlarmSoundScreen:
    AlarmRingingScreen:
